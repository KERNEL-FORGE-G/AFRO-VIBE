PORT=3000
JWT_SECRET=change_me

# Database mode:
# - auto: Firestore if Firebase credentials are present, otherwise SQLite.
# - firestore: online database mode.
# - sqlite: local/offline database mode.
DATABASE_MODE=auto

# Media storage:
# - auto: Cloudinary when Firestore is the active database, otherwise local uploads.
# - cloudinary: force Cloudinary for media uploads.
# - local: force local /uploads files.
MEDIA_STORAGE=auto

# Firestore online database (Firebase Admin SDK).
# Required for DATABASE_MODE=firestore and for /api/sync to push local SQLite data to Firestore.
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-firebase-project-id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Cloudinary online media storage.
# Required for MEDIA_STORAGE=cloudinary or online uploads in auto mode.
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Optional: force Cloudinary even when Firestore is disabled.
FORCE_CLOUDINARY=false
